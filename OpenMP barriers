/*

 This program demonstrates the use of OpenMP barriers to synchronize threads.
 A barrier forces all threads to wait until everyone reaches the same point
 before continuing execution.

*/

#include <iostream>
#include <omp.h>
using namespace std;

int main()
{
#pragma omp parallel
	{
		printf("First Thread %d \n",omp_get_thread_num());

#pragma omp barrier
		printf("Second Thread %d \n", omp_get_thread_num());

#pragma omp barrier
		printf("Third Thread %d \n", omp_get_thread_num());
	}
}
