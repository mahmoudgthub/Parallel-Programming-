// This program demonstrates the difference between serial and parallel execution using OpenMP.
// In the serial region, it prints information about threads and processors using a single thread.
// Then it enters a parallel region where multiple threads run simultaneously,
// and each thread prints the number of threads, processors, and maximum threads available.


#include<iostream>
#include <omp.h>
using namespace std;

int main() 
{
	//seriel region
	printf("Num of Threads: %d \n", omp_get_num_threads());      //1
	printf("Num of Procs: %d \n", omp_get_num_procs());          //8
	printf("Num of Max Threads: %d \n", omp_get_max_threads());  //8

#pragma omp parallel
	{
		printf("Num of Threads: %d \n", omp_get_num_threads());      //8
		printf("Num of Procs: %d \n", omp_get_num_procs());          //8
		printf("Num of Max Threads: %d \n", omp_get_max_threads());  //8
	}
}
